{
  "agent": {
    "play_sound_when_agent_done": true,
    "favorite_models": [],
    "notify_when_agent_waiting": "never",
    "model_parameters": [],
  },
  "buffer_line_height": "comfortable",
  "colorize_brackets": true,
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "agent_ui_font_size": 14.0,
  "gutter": {
    "line_numbers": false,
  },
  "buffer_font_weight": 400.0,
  "agent_buffer_font_size": 12,
  "auto_install_extensions": {
    "elixir": true,
    "fish": true,
    "html": true,
    "toml": true,
    "svelte": true,
  },
  "buffer_font_family": "TX-02",
  "buffer_font_size": 12,
  "collaboration_panel": {
    "button": false,
  },
  "current_line_highlight": "gutter",
  "cursor_blink": false,
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": [".env", "**/journal"],
    "mode": "subtle",
  },
  "file_types": {
    "CSS": ["scss"],
    "Shell Script": [".envrc", ".env"],
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "inlay_hints": {
    "enabled": false,
  },
  "languages": {
    "Elixir": {
      "language_servers": [
        "expert",
        "!elixir-ls",
        "!next-ls",
        "!lexical",
        "tailwindcss-language-server",
      ],
    },
    "HEEX": {
      "language_servers": [
        "expert",
        "!elixir-ls",
        "!next-ls",
        "!lexical",
        "tailwindcss-language-server",
      ],
    },
    "HTML": {
      "hard_tabs": false,
      "tab_size": 2,
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "hard_tabs": false,
      "tab_size": 2,
    },
    "Markdown": {
      "show_edit_predictions": false,
    },
    "Svelte": {
      "hard_tabs": false,
      "tab_size": 2,
    },
    "TypeScript": {
      "hard_tabs": false,
      "tab_size": 2,
    },
  },
  "lsp": {
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "validate": false,
        },
      },
    },
    "expert": {
      "binary": {
        "path": "/Users/petar/.local/bin/expert_darwin_arm64",
        "arguments": ["--stdio"],
      },
    },
  },
  "middle_click_paste": true,
  "preferred_line_length": 100,
  "project_panel": {
    "hide_root": false,
    "dock": "left",
  },
  "relative_line_numbers": "enabled",
  "scrollbar": {
    "show": "never",
  },
  "show_completions_on_input": true,
  "show_edit_predictions": true,
  "soft_wrap": "editor_width",
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "TX-02",
    "scrollbar": {
      "show": "auto",
    },
    "blinking": "off",
    "copy_on_select": true,
    "dock": "bottom",
    "env": {
      "TERM_PROGRAM": "zed",
    },
    "font_size": 12.0,
    "option_as_meta": true,
    "shell": {
      "with_arguments": {
        "title_override": "zsh",
        "args": ["-l", "-i"],
        "program": "/opt/homebrew/bin/fish",
      },
    },
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "theme": "Gruvbox Light Soft",
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
  },
  "ui_font_family": "iA Writer Duospace",
  "ui_font_size": 13.0,
  "use_autoclose": true,
  "vertical_scroll_margin": 5,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
}
