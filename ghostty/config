# vim: filetype=conf

# fish shell
command = /opt/homebrew/bin/fish -il
shell-integration = fish
shell-integration-features = sudo, title, ssh-terminfo

# fonts
font-family = Space Mono
font-size = 12
font-style-bold = Medium
adjust-cell-height = 4%

# colors
window-colorspace = display-p3
selection-invert-fg-bg = true
theme = light:Melange Light,dark:gondolin

# padding
window-padding-balance = true
window-padding-x = 7
window-padding-y = 7

# an empty bar, that's all I want
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs

# options
window-save-state = always
mouse-hide-while-typing = true
confirm-close-surface = false

# clipboard
copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow

# mac
macos-option-as-alt = false
bell-features = no-title,no-attention

# updates
auto-update = off
keybind = cmd+shift+u=check_for_updates

# split settings
unfocused-split-opacity = 0.75

# Unbind default keybinds for Alt-left and Alt-right to restore their normal behavior
keybind = alt+arrow_left=unbind
keybind = alt+arrow_right=unbind

# shift-enter in Claude
keybind = shift+enter=text:\n

# copy hovered hyperlink target (for file:// links from eza)
keybind = cmd+shift+y=copy_url_to_clipboard
