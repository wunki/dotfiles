fish_history
fishd.*
fish_read_history
fish_variables
/functions/*

# These files are managed by fisherman, so let's ignore them
/conf.d/*
/completions/*

# Allow some locally-managed configuration
!/conf.d/_*.fish
/conf.d/_pure_init.fish
/conf.d/_tide_init.fish
!/conf.d/[0-9]*.fish
!/conf.d/tide.gondolin.fish
!/conf.d/direnv.fish
!/conf.d/vite-plus.fish
!/completions/_*.fish
!/completions/vp.fish
!/completions/vpr.fish

# Exempted functions
!/functions/_tide_item_context.fish
!/functions/ls!.fish
!/functions/gg.fish
!/functions/_min*.fish
!/functions/update-abbreviations.fish
!/functions/update-abbreviations-*.fish
!/functions/theme_apply.fish
!/functions/theme_mode.fish
